# ========================
# Database Configuration
# ========================
# Prisma supports PostgreSQL and MSSQL
# Just change the DATABASE_URL to switch between databases

# PostgreSQL (default)
# For local development with Docker: postgresql://postgres:postgres@localhost:5432/google_opinion
# For Neon (cloud): Get from https://neon.tech
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/google_opinion"

# MSSQL (uncomment to use instead of PostgreSQL)
# Format: sqlserver://localhost:1433;database=google_opinion;user=sa;password=YourPassword;encrypt=true;trustServerCertificate=true
# DATABASE_URL="sqlserver://localhost:1433;database=google_opinion;user=sa;password=YourStrong@Passw0rd;encrypt=false;trustServerCertificate=true"

# ========================
# NextAuth.js Configuration
# ========================
# Your app URL (change in production)
NEXTAUTH_URL="http://localhost:3000"

# Secret for JWT encryption (MUST CHANGE IN PRODUCTION!)
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here-generate-with-openssl"

# ========================
# SMS Provider Configuration
# ========================
# SMS providers are configured in the dashboard (UI)
# Supported: SMSAPI.pl, Twilio, Vonage
# No environment variables needed - all config is in database

# ========================
# Application Settings
# ========================
# Public app URL (used in emails, SMS, etc.)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Environment (development | production)
NODE_ENV="development"

# ========================
# Cron Job Secret
# ========================
# Secret for authenticating cron job endpoints
# Generate with: openssl rand -base64 32
CRON_SECRET="your-cron-secret-here-generate-with-openssl"

# ========================
# Root User (Admin Account)
# ========================
# This user will be created on first startup
ROOT_USER_EMAIL="admin@example.com"
ROOT_USER_PASSWORD="change-this-password"
ROOT_USER_NAME="System Administrator"
